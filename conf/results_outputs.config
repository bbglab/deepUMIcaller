/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Config file for defining DSL2 per module options and publishing paths
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Available keys to override module options:
        ext.args   = Additional arguments appended to command in module.
        ext.args2  = Second set of arguments appended to command in module (multi-tool modules).
        ext.args3  = Third set of arguments appended to command in module (multi-tool modules).
        ext.prefix = File name prefix for output files.
----------------------------------------------------------------------------------------
*/

process {

    withName: SAMPLESHEET_CHECK {
        publishDir = [
            path: { "${params.outdir}/pipeline_info" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    withName: "FASTQC" {
        publishDir = [
            path: { "${params.outdir}/metrics/fastqc" },
            mode: params.publish_dir_mode,
            pattern: "**{html,zip}"
        ]
    }

    withName: 'QUALIMAPQCRAW' {
        publishDir = [
            path: { "${params.outdir}/metrics/coverage_n_depth/raw/qualimapqc" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
            ]
    }
    withName: 'QUALIMAPQCALLMOLECULES' {
        publishDir = [
            path: { "${params.outdir}/metrics/coverage_n_depth/all_molecules/qualimapqc" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }
    withName: 'QUALIMAPQCDUPLEX' {
        publishDir = [
            path: { "${params.outdir}/metrics/coverage_n_depth/duplex/qualimapqc" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    withName: 'DISCARDEDCOVERAGEGLOBAL' {
        publishDir = [
            path: { "${params.outdir}/metrics/coverage_n_depth/all_molecules/discardedcoverageglobal" },
            mode: params.publish_dir_mode,
            pattern: "*{bed}"
        ]
    }
    withName: 'DISCARDEDCOVERAGETARGETED' {
        publishDir = [
            path: { "${params.outdir}/metrics/coverage_n_depth/all_molecules/discardedcoveragetargeted" },
            mode: params.publish_dir_mode,
            pattern: "*{bed}"
        ]
    }

    withName: 'COVERAGEGLOBAL'{
        publishDir = [
            path: { "${params.outdir}/metrics/coverage_n_depth/duplex/coverageglobal" },
            mode: params.publish_dir_mode,
            pattern: "*{bed}"
        ]
    }
    withName: 'COVERAGETARGETED' {
        publishDir = [
            path: { "${params.outdir}/metrics/coverage_n_depth/duplex/coveragetargeted" },
            mode: params.publish_dir_mode,
            pattern: "*{bed}"
        ] 
    }

    withName: 'FAMILYMETRICS' {
       publishDir = [
            path: { "${params.outdir}/metrics/duplex/familymetrics" },
            mode: params.publish_dir_mode,
            pattern: "*{pdf,tsv}"
        ]
    }
    withName: 'FAMILYMETRICSONTARGET' {
       publishDir = [
            path: { "${params.outdir}/metrics/duplex/familymetricsontarget" },
            mode: params.publish_dir_mode,
            pattern: "*{pdf,tsv}"
        ]
    }

    withName: 'COLLECTSEQMETRICS' {
       publishDir = [
            path: { "${params.outdir}/metrics/duplex/fgbio_seqmetrics" },
            mode: params.publish_dir_mode,
            pattern: "*{pdf,txt}"
        ]
    }
    withName: 'COLLECTSEQMETRICSONTARGET' {
       publishDir = [
            path: { "${params.outdir}/metrics/duplex/fgbio_seqmetricsontarget" },
            mode: params.publish_dir_mode,
            pattern: "*{pdf,txt}"
        ]
    }

    withName: "FILTERLOWCOMPLEX|FILTERLOWMAPPABLE|FILTERNANOSEQSNP|FILTERNANOSEQNOISE" {
        publishDir       = [
                enabled : false
        ]
    }

    withName: "PILEUPBAM.*|QUERYTABIX|BEDTOINTERVAL|READJUSTREGIONS.*" {
        publishDir       = [
                enabled : false
        ]
    }

    withName: "PATCH_DEPTH" {
        publishDir = [
            path: { "${params.outdir}/mutations_analysis/mutated_reads" },
            mode: params.publish_dir_mode,
            pattern: "*.mutated_reads.tsv.gz"
        ]
    }

    withName: "PHASE_MUTATIONS" {
        publishDir = [
            path: { "${params.outdir}/mutations_analysis/phasing" },
            mode: params.publish_dir_mode,
            pattern: "*{tsv.gz,pdf}"
        ]
    }

    withName: "ANALYZE_PHASE_OUTPUTS" {
        publishDir = [
            path: { "${params.outdir}/mutations_analysis/phase_downstream_analysis" },
            mode: params.publish_dir_mode,
            pattern: "*{tsv.gz,pdf}"
        ]
    }

    withName: "MUTSPERPOS" {
        publishDir = [
            path: { "${params.outdir}/metrics/mutations/mutsperpos" },
            mode: params.publish_dir_mode,
            pattern: "*{png,csv}"
        ]
    }
    withName: "COHORTMUTSPERPOS" {
        publishDir = [
            path: { "${params.outdir}/metrics/mutations/mutsperpos_cohort_summary" },
            mode: params.publish_dir_mode,
            pattern: "*{pdf,tsv}"
        ]
    }

    withName: 'SIGPROFPLOT' {
        publishDir = [
            path: { "${params.outdir}/metrics/mutations/sigprofiler/all" },
            mode: params.publish_dir_mode,
            pattern: "**{all,pdf,txt}"
        ]
    }
    withName: 'SIGPROFPLOTPYR' {
        publishDir = [
            path: { "${params.outdir}/metrics/mutations/sigprofiler/pyrimidine" },
            mode: params.publish_dir_mode,
            pattern: "**{all,pdf,txt}"
        ]
    }
    withName: 'SIGPROFPLOTPUR' {
        publishDir = [
            path: { "${params.outdir}/metrics/mutations/sigprofiler/purine" },
            mode: params.publish_dir_mode,
            pattern: "**{all,pdf,txt}"
        ]
    }

    withName: "SORTBAMDUPLEXCONS" {
        publishDir = [
            path: { "${params.outdir}/duplex_reads_bam" },
            mode: params.publish_dir_mode,
            pattern: "*{bam,csi}"
        ]
    }
}
