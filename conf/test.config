/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Nextflow config file for running minimal tests
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Defines input files and everything required to run a fast and simple pipeline test.

    Use as follows:
        nextflow run bbglab/deepUMIcaller -profile test,<docker/singularity> --outdir <OUTDIR>

----------------------------------------------------------------------------------------
*/

params {
    config_profile_name        = 'Test profile'
    config_profile_description = 'Minimal test dataset to check pipeline function'

    // Input data
    // TODO nf-core: Specify the paths to your test data on nf-core/test-datasets
    // TODO nf-core: Give any required params for the test so that command line flags are not needed
    //input                   = 'assets/input_example.csv'
    input                   = 'assets/input_example_lanes.csv'

    // step = 'filterconsensus'
    // input  = 'assets/input_example.filterconsensus.step.csv'

    // step = 'allmoleculesfile'
    // input  = 'assets/input_example.allmoleculesfile.step.csv'

    // step = 'calling'
    // input  = 'assets/input_example.calling.step.csv'

    filter_min_reads_duplex = "2,1,1"        // default minimum input reads for fgbio's FILTERCONSENSUSREADS
}

process {
    resourceLimits = [ cpus: 56, memory: 640.GB, time: 60.m ]
}
