/*
========================================================================================
    Nextflow config file for running tests
========================================================================================
*/

// Load all cluster-specific reference paths (fasta, vep, cadd, nanoseq, etc.)
includeConfig '../conf/general_files_IRB.config'

params {
   config_profile_name        = 'Test profile'
   config_profile_description = 'Test dataset to check pipeline function'
    // Test-specific values that differ from pipeline defaults
    targetsfile               = '/data/bbg/nobackup2/scratch/fcalvet/fetch_duplex_fastqs/samplesheet/TP53_target.bed4.bed'
    right_clip                = 30          // default: 0
    asminusxs_thres           = 10          // default: 50
    projectname               = 'test_FASTQs'
    final_read_size           = 270         // default: 150
    filter_min_reads_duplex   = "2 1 1"     // default: 4 2 2
}

process {
    executor      = 'slurm'
    queue         = 'bbg_cpu_zen4,irb_cpu_zen4'
    errorStrategy = 'retry'
    maxRetries    = 2

    withLabel: process_high_memory {
        memory = { 200.GB * task.attempt }
    }

    // Suppress publishDir for PATCH_DEPTH during tests (results_outputs.config enables it)
    withName: 'PATCH_DEPTH' {
        publishDir = [enabled: false]
    }

    // MUTSPERPOS: keep only the test-specific errorStrategy override
    withName: MUTSPERPOS {
        errorStrategy = 'ignore'
    }
}

executor {
   queueSize = 600
}

singularity {
   cacheDir = '/data/bbg/datasets/pipelines/nextflow_containers'
   libraryDir = '/data/bbg/datasets/pipelines/nextflow_containers'
   autoMounts = true
   runOptions = '-B /data/bbg'
}

// Enable trace, timeline, report and DAG for tests
trace {
    enabled = true
    file    = "${params.outdir}/pipeline_info/execution_trace.txt"
    fields  = 'task_id,hash,native_id,process,tag,name,status,exit,module,container,cpus,time,disk,memory,attempt,submit,start,complete,duration,realtime,queue,%cpu,%mem,rss,vmem,peak_rss,peak_vmem,rchar,wchar,syscr,syscw,read_bytes,write_bytes'
}

timeline {
    enabled = true
    file    = "${params.outdir}/pipeline_info/execution_timeline.html"
}

report {
    enabled = true
    file    = "${params.outdir}/pipeline_info/execution_report.html"
}

dag {
    enabled = true
    file    = "${params.outdir}/pipeline_info/pipeline_dag.html"
    verbose = false
}

